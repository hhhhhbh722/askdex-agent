# 应用
APP_NAME=enterprise-ai-agent
APP_ENV=development
DEBUG=true
API_PREFIX=/api/v1
HOST=0.0.0.0
PORT=8000

# OpenAI 兼容 API（DeepSeek / OpenAI / 其他）
# DeepSeek:  base_url=https://api.deepseek.com      model=deepseek-v4-pro 或 deepseek-v4-flash
# OpenAI:    base_url=https://api.openai.com/v1      model=gpt-4o
OPENAI_API_KEY=your-api-key-here
OPENAI_API_BASE=https://api.deepseek.com
OPENAI_MODEL=deepseek-v4-pro

# PostgreSQL（自动转换 psycopg2 → asyncpg）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Embedding（OpenAI 兼容 API，如 DashScope qwen3-vl-embedding）
# 留空则自动复用 OPENAI_API_KEY / OPENAI_API_BASE
EMBEDDING_API_KEY=
EMBEDDING_API_BASE=
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1024

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=
MILVUS_COLLECTION_NAME=agent_knowledge

# 日志
LOG_LEVEL=INFO
